<UserControl x:Class="Universal_x86_Tuning_Utility.Views.Dialogs.ReloadingGamesDialogView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Universal_x86_Tuning_Utility.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fluentAvaloniaControls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Universal_x86_Tuning_Utility.ViewModels"
             xmlns:dialogs="clr-namespace:Universal_x86_Tuning_Utility.ViewModels.Dialogs"
             mc:Ignorable="d"
             x:DataType="dialogs:ReloadingGamesDialogViewModel">
    <controls:CardControl Height="NaN"
                          Padding="80,40"
                          HorizontalAlignment="Center"
                          HorizontalContentAlignment="Center"
                          Background="#2B2B2B">
        <StackPanel HorizontalAlignment="Center">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="24"
                       Text="{Binding Title}" />
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="{Binding Description}" />
            <fluentAvaloniaControls:ProgressRing Margin="0,15,0,0"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
        </StackPanel>
    </controls:CardControl>
</UserControl>
