                <controls:IconExpander Icon="TopSpeed"
                                       IsVisible="{Binding IsAmdPboSettingAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize AMDPrecisionBoostOverdrive}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize AMDPrecisionBoostOverdriveDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize PBOScalar}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     VerticalAlignment="Bottom"
                                                     ToolTip.Tip="{localization:Localize AllowsControlPBOScalar}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsPboScalar, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.PboScalar, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="10"
                                              Minimum="1"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.PboScalar, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="10"
                                        Minimum="1"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="TopSpeed"
                                       IsVisible="{Binding IsAmdCOSettingAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize AMDCurveOptimiser}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize AMDCurveOptimiserDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize AllCoreOffset}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     VerticalAlignment="Bottom"
                                                     ToolTip.Tip="{localization:Localize AllowsControlAllCoreCurveOptimiser}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsCoAllCore, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.CoAllCore, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="30"
                                              Minimum="-50"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.CoAllCore, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="30"
                                        Minimum="-50"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,8,0,0">
                                    <TextBlock FontWeight="DemiBold"
                                               FontSize="13"
                                               Text="{localization:Localize iGPUOffset}" />
                                    <avalonia:FluentIcon Icon="Info"
                                                         FontSize="24"
                                                         IconVariant="Regular"
                                                         Margin="6,0,0,-2"
                                                         VerticalAlignment="Bottom"
                                                         ToolTip.Tip="{localization:Localize AllowsControliGPUCurveOptimiser}" />
                                </StackPanel>
                                <Grid ColumnDefinitions="33,150,*"
                                      Margin="0,8,0,0">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding SelectedPreset.IsCoGfx, UpdateSourceTrigger=PropertyChanged}" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding SelectedPreset.CoGfx, UpdateSourceTrigger=PropertyChanged}"
                                                  Maximum="30"
                                                  Minimum="-50"
                                                  SmallChange="1" />
                                    <Slider Grid.Column="2"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"
                                            Value="{Binding SelectedPreset.CoGfx, UpdateSourceTrigger=PropertyChanged}"
                                            Maximum="30"
                                            Minimum="-50"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="TopSpeed"
                                       IsVisible="{Binding IsAmdCCD1COSettingAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize AMDPerCoreCurveOptimiserCCD1}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize AMDPerCoreCurveOptimiserDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <ItemsControl
                        ItemsSource="{Binding SelectedPreset.Ccd1States, UpdateSourceTrigger=PropertyChanged}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AmdCcdCoreState}">
                                <StackPanel Margin="0,-8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="DemiBold"
                                                   FontSize="13"
                                                   Text="{Binding CoreIndex, StringFormat={}Core {0} Offset}" />
                                        <avalonia:FluentIcon Icon="Info"
                                                             FontSize="20"
                                                             IconVariant="Regular"
                                                             Margin="6,0,0,-2"
                                                             ToolTip.Tip="{Binding CoreIndex, StringFormat={}Allows control to change the Curve Optimiser Frequency/Voltage curve offset for core {1}}"
                                                             VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Grid ColumnDefinitions="33, 150, *"
                                          Margin="0,8,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" />

                                        <ui:NumberBox Grid.Column="1"
                                                      Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                      Maximum="30"
                                                      Minimum="-50"
                                                      SmallChange="1" />
                                        <Slider Grid.Column="2"
                                                Margin="12,0,0,0"
                                                Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                Maximum="30"
                                                Minimum="-50"
                                                TickFrequency="1"
                                                VerticalAlignment="Center"
                                                IsSnapToTickEnabled="True" />
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:IconExpander>

                <controls:IconExpander Icon="TopSpeed"
                                       IsVisible="{Binding IsAmdCCD2COSettingAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize AMDPerCoreCurveOptimiserCCD2}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize AMDPerCoreCurveOptimiserDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <ItemsControl
                        ItemsSource="{Binding SelectedPreset.Ccd2States, UpdateSourceTrigger=PropertyChanged}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AmdCcdCoreState}">
                                <StackPanel Margin="0,-8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="DemiBold"
                                                   FontSize="13"
                                                   Text="{Binding CoreIndex, StringFormat={}Core {0} Offset}" />
                                        <avalonia:FluentIcon Icon="Info"
                                                             FontSize="20"
                                                             IconVariant="Regular"
                                                             Margin="6,0,0,-2"
                                                             ToolTip.Tip="{Binding CoreIndex, StringFormat={}Allows control to change the Curve Optimiser Frequency/Voltage curve offset for core {1}}"
                                                             VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Grid ColumnDefinitions="33, 150, *"
                                          Margin="0,8,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" />

                                        <ui:NumberBox Grid.Column="1"
                                                      Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                      Maximum="30"
                                                      Minimum="-50"
                                                      SmallChange="1" />
                                        <Slider Grid.Column="2"
                                                Margin="12,0,0,0"
                                                Value="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                Maximum="30"
                                                Minimum="-50"
                                                TickFrequency="1"
                                                VerticalAlignment="Center"
                                                IsSnapToTickEnabled="True" />
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:IconExpander>
                
                <controls:IconCardControl Icon="Grid"
                                          IconSize="20"
                                          IsVisible="{Binding IsCcdAffinityAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="14"
                            FontWeight="Medium"
                            Text="{localization:Localize CCDAffinityMode}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Text="{localization:Localize CCDAffinityModeDesc}"/>
                    </StackPanel>
                    <controls:IconCardControl.RightMenuContent>
                        <ComboBox VerticalAlignment="Center"
                                  ItemsSource="{Binding CcdAffinityModes, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValue="{Binding SelectedPreset.CcdAffinity, UpdateSourceTrigger=PropertyChanged}" 
                                  MinWidth="164" 
                                  Height="37"/>
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>

                <controls:IconCardControl
                    IsVisible="{Binding IsAmdPowerProfileSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="FastAcceleration">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="Medium"
                                   Text="{localization:Localize AMDBoostProfile}" />
                        <TextBlock FontSize="12"
                                   Text="{localization:Localize AMDBoostProfileDesc}" />
                    </StackPanel>
                    <controls:IconCardControl.RightMenuContent>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding AmdPowerProfiles}"
                                  SelectedValue="{Binding SelectedPreset.BoostProfile, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberBinding="{Binding Name}"
                                  MinWidth="164"
                                  Height="37" />
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>

                <controls:IconCardControl
                    IsVisible="{Binding IsChangeRefreshRateAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="Desktop">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="Medium"
                                   Text="{localization:Localize DisplayRefreshRate}" />
                        <TextBlock FontSize="12"
                                   Text="{localization:Localize DisplayRefreshRateDesc}" />
                    </StackPanel>
                    <controls:IconCardControl.RightMenuContent>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <ComboBox ItemsSource="{Binding AvailableDisplays, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValue="{Binding SelectedDisplay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberBinding="{Binding Name}"
                                      IsVisible="{Binding !!AvailableDisplays.Count}"
                                      VerticalAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      MinWidth="164"
                                      Height="37" />
                            <Button Command="{Binding IdentificateMonitorsCommand}"
                                    ToolTip.Tip="{localization:Localize IdentificateMonitors}"
                                    Height="37">
                                <avalonia:FluentIcon Icon="Eye" />
                            </Button>
                            <ComboBox
                                ItemsSource="{Binding SupportedRefreshRates, UpdateSourceTrigger=PropertyChanged}"
                                SelectedValue="{Binding SelectedPreset.DisplayHz, UpdateSourceTrigger=PropertyChanged}"
                                DisplayMemberBinding="{Binding }"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                MinWidth="164"
                                Height="37" />
                        </StackPanel>
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>

                <controls:IconCardControl Icon="Power">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="Medium"
                                   Text="{localization:Localize PowerMode}" />
                        <TextBlock FontSize="12"
                                   Text="{localization:Localize PowerModeDesc}" />
                    </StackPanel>
                    <controls:IconCardControl.RightMenuContent>
                        <ComboBox VerticalAlignment="Center"
                                  ItemsSource="{Binding PowerModes}"
                                  DisplayMemberBinding="{Binding Name}"
                                  SelectedValue="{Binding SelectedPreset.PowerMode, UpdateSourceTrigger=PropertyChanged}"
                                  MinWidth="164"
                                  Height="37" />
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>

                <controls:IconCardControl
                    IsVisible="{Binding IsAsusPowerSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="Power">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="Medium"
                                   Text="{localization:Localize ASUSPowerProfile}" />
                        <TextBlock FontSize="12"
                                   Text="{localization:Localize ASUSPowerProfileDesc}" />
                    </StackPanel>
                    <controls:IconCardControl.RightMenuContent>
                        <ComboBox VerticalAlignment="Center"
                                  SelectedValue="{Binding SelectedAsusPowerProfile, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AsusPowerProfiles, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberBinding="{Binding Title}"
                                  MinWidth="164"
                                  Height="37" />
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>

                <controls:IconCardControl
                    IsVisible="{Binding IsAsusGpuUltimateSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="FastAcceleration">
                    <StackPanel>
                        <TextBlock FontSize="14"
                                   FontWeight="Medium"
                                   Text="{localization:Localize ASUSGPUUltimateMode}" />
                        <TextBlock FontSize="12"
                                   Text="{localization:Localize ASUSGPUUltimateModeDesc}" />
                    </StackPanel>

                    <controls:IconCardControl.RightMenuContent>
                        <ToggleSwitch
                            IsChecked="{Binding SelectedPreset.IsAsusGpuUlti, UpdateSourceTrigger=PropertyChanged}"
                            Command="{Binding AsusGpuUltimateModSwitchedCommand}" />
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>

                <controls:IconCardControl
                    IsVisible="{Binding IsAsusEcoModeAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="LeafTwo">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="Medium"
                                   Text="{localization:Localize ASUSiGPUOnlyMode}" />
                        <TextBlock FontSize="12"
                                   Text="{localization:Localize ASUSiGPUOnlyModeDesc}" />
                    </StackPanel>
                    <controls:IconCardControl.RightMenuContent>
                        <ToggleSwitch
                            IsChecked="{Binding SelectedPreset.AsusIGpu, UpdateSourceTrigger=PropertyChanged}" />
                    </controls:IconCardControl.RightMenuContent>
                </controls:IconCardControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>