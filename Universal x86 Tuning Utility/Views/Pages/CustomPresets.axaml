                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <ToggleSwitch Margin="0,0,9,0"
                                              IsChecked="{Binding SelectedPreset.IsIntelVoltages, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </controls:IconExpander.Header>
                    <StackPanel>
