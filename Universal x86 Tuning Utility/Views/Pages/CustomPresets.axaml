                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelVoltageCpu, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="250"
                                        Minimum="-250"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize iGPUOffsetmV}" />
                                </StackPanel>

                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.IntelVoltageGpu, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="250"
                                              Minimum="-250"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelVoltageGpu, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="250"
                                        Minimum="-250"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
