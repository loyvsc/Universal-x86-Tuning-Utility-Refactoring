<UserControl x:Class="Universal_x86_Tuning_Utility.Views.Pages.CustomPresetsPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:viewmodels="clr-namespace:Universal_x86_Tuning_Utility.ViewModels"
             xmlns:models="clr-namespace:ApplicationCore.Models;assembly=ApplicationCore"
             xmlns:controls="clr-namespace:Universal_x86_Tuning_Utility.Controls"
             xmlns:avalonia="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
             xmlns:localization="clr-namespace:Universal_x86_Tuning_Utility.Localization"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="2500"
             x:DataType="viewmodels:CustomPresetsViewModel">
    <UserControl.Styles>
        <Style Selector="ui|NumberBox">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>
    <DockPanel>
        <TextBlock FontSize="{StaticResource HeaderFontSize}"
                   FontWeight="Medium"
                   Text="{localization:Localize CustomPresets}"
                   DockPanel.Dock="Top"
                   Margin="18,10,0,0" />

        <DockPanel DockPanel.Dock="Top"
                   Margin="18,9,18,0">
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Left"
                        HorizontalAlignment="Left">
                <TextBlock FontSize="17"
                           FontWeight="Medium"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Text="{localization:Localize SavedPresets}" />
                <ComboBox Width="225"
                          ItemsSource="{Binding AvailablePresets, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValue="{Binding SelectedPreset, UpdateSourceTrigger=PropertyChanged}"
                          Height="37" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <TextBlock FontSize="17"
                           FontWeight="Medium"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Text="{localization:Localize NewPresetName}" />
                <TextBox Margin="0,0,-2,0"
                         Width="225"
                         Height="35"
                         Text="{Binding SelectedPreset.Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </DockPanel>

        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,9,9,6">
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,9,9"
                    Height="40"
                    DockPanel.Dock="Bottom"
                    Width="50"
                    IsVisible="{Binding UndoActionAvailable, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip.Tip="{localization:Localize UndoOverclockSettings}"
                    Command="{Binding UndoCommand}">
                <ui:SymbolIcon Symbol="Sync" FontSize="24" />
            </Button>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,9,9"
                    Height="40"
                    DockPanel.Dock="Bottom"
                    Width="50"
                    ToolTip.Tip="{localization:Localize ReloadSettingsOfCurrentPresetValues}"
                    Command="{Binding ReloadPresetValuesCommand}">
                <ui:SymbolIcon Symbol="Sync" FontSize="24" />
            </Button>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,9,9"
                    Height="40"
                    DockPanel.Dock="Bottom"
                    Width="50"
                    ToolTip.Tip="{localization:Localize DeleteCurrentSettingsPreset}"
                    Command="{Binding DeletePresetCommand}">
                <ui:SymbolIcon Symbol="Delete" FontSize="24" />
            </Button>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,9,9"
                    Height="40"
                    DockPanel.Dock="Bottom"
                    Width="50"
                    ToolTip.Tip="{localization:Localize SaveCurrentSettingsAsNewPreset}"
                    Command="{Binding SavePresetCommand}">
                <ui:SymbolIcon Symbol="SaveFilled" FontSize="24" />
            </Button>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,9,9"
                    Height="40"
                    Width="50"
                    DockPanel.Dock="Bottom"
                    ToolTip.Tip="{localization:Localize ApplyCurrentSettings}"
                    Command="{Binding ApplyPresetCommand}">
                <ui:SymbolIcon Symbol="Document" FontSize="24" />
            </Button>
        </StackPanel>

        <ScrollViewer Margin="0,9,0,0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      IsDeferredScrollingEnabled="False">
            <StackPanel Margin="15,0,15,0"
                        Spacing="8">
                <controls:IconExpander
                    IsVisible="{Binding IsAmdApuSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    DockPanel.Dock="Top"
                    Icon="Temperature">
                    <controls:IconExpander.Header>
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize APUTemperatureTuning}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize APUTemperatureTuningDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <controls:IconExpander.Content>
                        <StackPanel>
                            <StackPanel Margin="0,-8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="DemiBold"
                                               FontSize="13"
                                               Text="{localization:Localize TemperatureLimitC}" />
                                    <avalonia:FluentIcon Icon="Info"
                                                         FontSize="20"
                                                         Margin="6,0,0,-2"
                                                         ToolTip.Tip="{localization:Localize ControlsTempLimitAPUSoftThrottling}"
                                                         VerticalAlignment="Bottom" />
                                </StackPanel>

                                <Grid ColumnDefinitions="33, 150, *"
                                      Margin="0,8,0,0">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding SelectedPreset.IsApuTemp, UpdateSourceTrigger=PropertyChanged}" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding SelectedPreset.ApuTemperature, UpdateSourceTrigger=PropertyChanged}"
                                                  Maximum="105"
                                                  Minimum="10"
                                                  SmallChange="1" />
                                    <Slider Grid.Column="2"
                                            Value="{Binding SelectedPreset.ApuTemperature, UpdateSourceTrigger=PropertyChanged}"
                                            Maximum="105"
                                            Minimum="10"
                                            TickFrequency="1"
                                            VerticalAlignment="Center"
                                            IsSnapToTickEnabled="True" />
                                </Grid>
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="DemiBold"
                                               FontSize="13"
                                               Text="{localization:Localize SkinTemperatureLimitC}" />
                                    <avalonia:FluentIcon Icon="Info"
                                                         FontSize="20"
                                                         Margin="6,0,0,-2"
                                                         ToolTip.Tip="{localization:Localize ControlsChassisTempLimitAPUThrottling}"
                                                         VerticalAlignment="Bottom" />
                                </StackPanel>
                                <Grid ColumnDefinitions="33, 150, *"
                                      Margin="0,8,0,0">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding SelectedPreset.IsApuSkinTemp, UpdateSourceTrigger=PropertyChanged}" />
                                    <ui:NumberBox Grid.Column="1"
                                                  Value="{Binding SelectedPreset.ApuSkinTemperature, UpdateSourceTrigger=PropertyChanged}"
                                                  Maximum="105"
                                                  Minimum="8"
                                                  SmallChange="1" />
                                    <Slider Grid.Column="2"
                                            Value="{Binding SelectedPreset.ApuSkinTemperature, UpdateSourceTrigger=PropertyChanged}"
                                            Maximum="105"
                                            Minimum="8"
                                            Margin="12,0,0,0"
                                            TickFrequency="1"
                                            VerticalAlignment="Center"
                                            IsSnapToTickEnabled="True" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </controls:IconExpander.Content>
                </controls:IconExpander>

                <controls:IconExpander Icon="Temperature"
                                       IsVisible="{Binding IsAmdCpuThermalSettingsAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock
                                FontSize="14"
                                FontWeight="Medium"
                                Text="{localization:Localize CPUTemperatureTuning}" />
                            <TextBlock
                                FontSize="12"
                                Text="{localization:Localize CPUTemperatureTuningDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize TemperatureLimitC}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     VerticalAlignment="Bottom"
                                                     ToolTip.Tip="{localization:Localize ControlsTempLimitCPUHardThrottling}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="33, 150, *" Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsDtCpuTemp, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.DtCpuTemperature, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="95"
                                              Minimum="10"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Value="{Binding SelectedPreset.DtCpuTemperature, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="95"
                                        Minimum="10"
                                        Margin="12,0,0,0"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander
                    IsVisible="{Binding IsAmdApuSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="Power">
                    <controls:IconExpander.Header>
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize APUPowerTuning}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize APUPowerTuningDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize STAPMPowerLimitW}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsAPUSTAPMPowerLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsApuStapmPow, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.ApuStapmPower, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="300"
                                              Minimum="5"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Value="{Binding SelectedPreset.ApuStapmPower, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="300"
                                        Minimum="5"
                                        Margin="12,0,0,0"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize SlowPowerLimitW}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsAPUSlowBoostDuration}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *" Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsApuSlowPow, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.ApuSlowPower, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="300"
                                              Minimum="5"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Value="{Binding SelectedPreset.ApuSlowPower, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="300"
                                        Minimum="5"
                                        Margin="12,0,0,0"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize SlowBoostDurationS}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsAPUSlowBoostPowerLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsApuSlowTime, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox
                                    Value="{Binding SelectedPreset.ApuSlowTime, UpdateSourceTrigger=PropertyChanged}"
                                    Maximum="1024"
                                    Minimum="2" Grid.Column="1" SmallChange="1" />
                                <Slider
                                    Value="{Binding SelectedPreset.ApuSlowTime, UpdateSourceTrigger=PropertyChanged}"
                                    Maximum="1024"
                                    Minimum="2" Grid.Column="2" Margin="12,0,0,0"
                                    TickFrequency="1" VerticalAlignment="Center" IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize FastPowerLimitW}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsAPUFastBoostDuration}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsApuFastPow, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.ApuFastPower, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="300"
                                              Minimum="5"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Value="{Binding SelectedPreset.ApuFastPower, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="300"
                                        Minimum="5"
                                        Margin="12,0,0,0"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize FastBoostDurationS}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsAPUFastBoostPowerLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsApuStapmTime, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.ApuStapmTime, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="1024"
                                              Minimum="2"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.ApuStapmTime, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="1024"
                                        Minimum="2"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander
                    IsVisible="{Binding IsAmdCpuSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="Power">
                    <controls:IconExpander.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontSize="14"
                                FontWeight="Medium"
                                Text="{localization:Localize CPUPowerTuning}" />
                            <TextBlock
                                FontSize="12"
                                Text="{localization:Localize CPUPowerTuningDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize PPTLimitW}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsCPUPPTLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsDtCpuPpt, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.DtCpuPpt, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="300"
                                              Minimum="8"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Value="{Binding SelectedPreset.DtCpuPpt, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="300"
                                        Minimum="8"
                                        TickFrequency="1"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize EDCLimitA}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsCPUEDCLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsDtCpuEdc, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.DtCpuEdc, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="900"
                                              Minimum="8"
                                              SmallChange="25" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Value="{Binding SelectedPreset.DtCpuEdc, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="900"
                                        Minimum="8"
                                        TickFrequency="25"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize TDCLimitA}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsCPUTDCLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsDtCpuTdc, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.DtCpuTdc, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="900"
                                              Minimum="8"
                                              SmallChange="25" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Value="{Binding SelectedPreset.DtCpuTdc, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="900"
                                        Minimum="8"
                                        TickFrequency="25"
                                        VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander
                    IsVisible="{Binding IsIntelSettingsAvailable, UpdateSourceTrigger=PropertyChanged}"
                    Icon="Power">
                    <controls:IconExpander.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize CPUPowerTuning}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize CPUPowerTuningDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize PowerLimitW}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsCPUTotalPowerLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsIntelPl1, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.IntelPl1, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="400"
                                              Minimum="8"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelPl1, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="400"
                                        Minimum="8"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0"
                                    IsVisible="False">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize PowerLimit2W}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsCPUShortBoostPowerLimit}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *" Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsIntelPl2, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.IntelPl2, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="400"
                                              Minimum="8"
                                              SmallChange="25" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelPl2, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="400"
                                        Minimum="8"
                                        TickFrequency="25"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="Flash"
                                       IsVisible="{Binding IsAmdApuVrmSettingAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       FontWeight="Medium"
                                       Text="{localization:Localize APUVRMTuning}" />
                            <TextBlock FontSize="12"
                                       Text="{localization:Localize APUVRMTuningDesc}" />
                        </StackPanel>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize CPUTDCLimitA}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     VerticalAlignment="Bottom"
                                                     ToolTip.Tip="{localization:Localize ControlsCPUTDCLimit}" />
                            </StackPanel>
                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsApuCpuTdc, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.ApuCpuTdc, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="300"
                                              Minimum="8"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        Value="{Binding SelectedPreset.ApuCpuTdc, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="300"
                                        Minimum="8"
                                        TickFrequency="1"
