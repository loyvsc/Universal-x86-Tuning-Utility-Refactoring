                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize CacheOffsetmV}" />
                                </StackPanel>

                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.IntelVoltageCache, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="250"
                                              Minimum="-250"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelVoltageCache, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="250"
                                        Minimum="-250"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
