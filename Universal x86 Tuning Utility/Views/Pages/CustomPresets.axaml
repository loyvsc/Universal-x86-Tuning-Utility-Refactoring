                        <TextBlock FontSize="12"
                                   Margin="0,8,0,0"
                                   Text="{localization:Localize WarningHardwareDamages}"
                                   TextWrapping="WrapWithOverflow" />
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="Pulse"
                                       IsVisible="{Binding IsAmdCpuTuneSettingAvailable, UpdateSourceTrigger=PropertyChanged}">
