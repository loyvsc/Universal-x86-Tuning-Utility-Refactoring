                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.IntelBalCpu, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="31"
                                              Minimum="0"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelBalCpu, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="31"
                                        Minimum="0"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize GPUBalance}" />
                                </StackPanel>

                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.IntelBalGpu, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="31"
                                              Minimum="0"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.IntelBalGpu, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="31"
                                        Minimum="0"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="Pulse"
                                       IsVisible="{Binding IsIntelSettingsAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="Medium"
                                           Text="{localization:Localize IntelClockRatioControl}" />
                                <TextBlock FontSize="12"
                                           Text="{localization:Localize IntelClockRatioControlDesc}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <ToggleSwitch Margin="0,0,9,0"
                                              IsChecked="{Binding SelectedPreset.IsIntelClockRatio, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </controls:IconExpander.Header>
                    <ItemsControl
                        ItemsSource="{Binding SelectedPreset.IntelClockRatios, UpdateSourceTrigger=PropertyChanged}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:IntelClockRatio}">
                                <StackPanel Margin="0,-8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="DemiBold"
                                                   FontSize="13"
                                                   Text="{Binding CoreGroupIndex, StringFormat={}Core Group {0}}" />
                                        <avalonia:FluentIcon Icon="Info"
                                                             FontSize="20"
                                                             IconVariant="Regular"
                                                             Margin="6,0,0,-2"
                                                             ToolTip.Tip="{localization:Localize ControlsMaximumVoltageGPU}"
                                                             VerticalAlignment="Bottom" />
                                    </StackPanel>

                                    <Grid ColumnDefinitions="150, *"
                                          Margin="0,8,0,0">
                                        <ui:NumberBox Grid.Column="0"
                                                      Value="{Binding Ratio, UpdateSourceTrigger=PropertyChanged}"
                                                      Maximum="83"
                                                      Minimum="4" SmallChange="1" />
                                        <Slider Grid.Column="1"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Center"
                                                Value="{Binding Ratio, UpdateSourceTrigger=PropertyChanged}"
                                                Maximum="83"
                                                Minimum="4"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True" />
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </controls:IconExpander>

                <controls:IconExpander Icon="Pulse"
                                       IsVisible="{Binding IsIntelSettingsAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center">
