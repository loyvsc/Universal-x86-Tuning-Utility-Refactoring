                                        VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="Medium"
                                           Text="{localization:Localize IntelPowerBalance}" />
                                <TextBlock FontSize="12"
                                           Text="{localization:Localize IntelPowerBalanceDesc}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <ToggleSwitch Margin="0,0,9,0"
                                              IsChecked="{Binding SelectedPreset.IsIntelBal, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize CPUBalance}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsMaximumVoltageGPU}"
                                                     VerticalAlignment="Bottom" />
