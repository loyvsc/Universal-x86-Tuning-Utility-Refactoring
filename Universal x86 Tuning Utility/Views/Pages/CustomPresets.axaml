                                        VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="Medium"
                                           Text="{localization:Localize UXTUSuperResolution}" />
                                <TextBlock FontSize="12"
                                           Text="{localization:Localize UXTUSuperResolutionDesc}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Grid.Column="1">
                                <ToggleSwitch Margin="0,0,9,0"
                                              IsChecked="{Binding SelectedPreset.IsMag, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox FontSize="13"
                                      FontWeight="DemiBold"
                                      Content="{localization:Localize EnableVSync}"
                                      IsChecked="{Binding SelectedPreset.IsVsync, UpdateSourceTrigger=PropertyChanged}" />
