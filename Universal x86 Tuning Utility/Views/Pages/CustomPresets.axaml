                                                 FontSize="20"
                                                 Margin="6,0,0,-2"
                                                 ToolTip.Tip="{localization:Localize SynchronisesCaptureFrameRate}"
                                                 VerticalAlignment="Top" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Width="130"
                                      FontSize="13"
                                      FontWeight="DemiBold"
                                      Content="{localization:Localize AutoRecapture}"
                                      IsChecked="{Binding SelectedPreset.IsRecap, UpdateSourceTrigger=PropertyChanged}" />
                            <avalonia:FluentIcon Icon="Info"
                                                 FontSize="20"
                                                 Margin="6,0,0,-2"
                                                 ToolTip.Tip="{localization:Localize AutoRecapturesPreviousCapture}"
                                                 VerticalAlignment="Top" />
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize CaptureSharpnessPercent}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsUXTUSuperResolutionSharpness}"
                                                     VerticalAlignment="Top" />
                            </StackPanel>

                            <Grid ColumnDefinitions="150, *">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.Sharpness, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="100"
                                              Minimum="5"
                                              SmallChange="1" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.Sharpness, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="100"
                                        Minimum="5"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize ResolutionScale}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsResolutionOfWindow}"
                                                     VerticalAlignment="Top" />
                            </StackPanel>
                            <ComboBox Margin="0,8,0,0"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding UXTUSuperResolutionScales}"
                                      SelectedValue="{Binding SelectedPreset.ResolutionScale, UpdateSourceTrigger=PropertyChanged}"
                                      MinWidth="138"
                                      Height="37">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:UXTUSuperResolutionScale">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="Image"
                                       IsVisible="{Binding IsRadeonGpuSettingsAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="Medium"
                                           Text="{localization:Localize RadeonGraphicsOptions}" />
                                <TextBlock FontSize="12"
                                           Text="{localization:Localize RadeonGraphicsOptionsDesc}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <ToggleSwitch Margin="0,0,9,0"
                                              IsChecked="{Binding SelectedPreset.IsRadeonGraphics, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox FontSize="13"
                                      FontWeight="DemiBold"
                                      Content="{localization:Localize RadeonAntiLag}"
                                      IsChecked="{Binding SelectedPreset.IsAntiLag, UpdateSourceTrigger=PropertyChanged}" />
                            <avalonia:FluentIcon Icon="Info"
                                                 FontSize="20"
                                                 Margin="6,0,0,-4"
                                                 ToolTip.Tip="{localization:Localize EnablesAMDRadeonAntiLag}"
                                                 VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize RadeonSuperResolutionPercent}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize EnablesAMDRadeonSuperResolution}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>

                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsRsr, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.Rsr, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="100"
                                              Minimum="5"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0"
                                        Value="{Binding SelectedPreset.Rsr, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="100"
                                        Minimum="5"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize RadeonBoostPercent}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize EnablesAMDRadeonBoost}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>

                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsBoost, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.Boost, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="83"
                                              Minimum="50"
                                              SmallChange="1" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.Boost, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="83"
                                        Minimum="50"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize RadeonImageSharpeningPercent}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize EnablesAMDRadeonImageSharpening}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>

                            <Grid ColumnDefinitions="33, 150, *"
                                  Margin="0,8,0,0">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding SelectedPreset.IsImageSharp, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SelectedPreset.ImageSharp, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="100"
                                              Minimum="10"
                                              SmallChange="5" />
                                <Slider Grid.Column="2"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.ImageSharp, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="100"
                                        Minimum="10"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox FontSize="13"
                                      FontWeight="DemiBold"
                                      Content="{localization:Localize EnhancedSync}"
                                      IsChecked="{Binding SelectedPreset.IsSync, UpdateSourceTrigger=PropertyChanged}" />
                            <avalonia:FluentIcon Icon="Info"
                                                 FontSize="24"
                                                 Margin="6,0,0,-4"
                                                 ToolTip.Tip="{localization:Localize EnablesAMDEnhancedSync}"
                                                 VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="Pulse"
                                       IsVisible="{Binding IsNvidiaGpuSettingsAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="14"
                                           FontWeight="Medium"
                                           Text="{localization:Localize NVIDIAGPUTuning}" />
                                <TextBlock FontSize="12"
                                           Text="{localization:Localize NVIDIAGPUTuningDesc}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <ToggleSwitch Margin="0,0,9,0"
                                              IsChecked="{Binding SelectedPreset.IsNvidia, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </controls:IconExpander.Header>
                    <StackPanel>
                        <StackPanel Margin="0,-8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize FrequencyAdjustedVoltageLimitMHz}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsMaximumVoltageGPU}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>

                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.NvMaxCoreClk, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="4000"
                                              Minimum="400"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.NvMaxCoreClk, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="4000"
                                        Minimum="400"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize GPUCoreClockOffsetMHz}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsClockOffsetNVIDIAGPUCore}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>

                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.NvCoreClk, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="2000"
                                              Minimum="-500"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.NvCoreClk, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="2000"
                                        Minimum="-500"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="DemiBold"
                                           FontSize="13"
                                           Text="{localization:Localize GPUMemoryClockOffsetMHz}" />
                                <avalonia:FluentIcon Icon="Info"
                                                     FontSize="20"
                                                     Margin="6,0,0,-2"
                                                     ToolTip.Tip="{localization:Localize ControlsClockOffsetNVIDIAGPUVRAM}"
                                                     VerticalAlignment="Bottom" />
                            </StackPanel>

                            <Grid ColumnDefinitions="150, *"
                                  Margin="0,8,0,0">
                                <ui:NumberBox Grid.Column="0"
                                              Value="{Binding SelectedPreset.NvMemClk, UpdateSourceTrigger=PropertyChanged}"
                                              Maximum="2000"
                                              Minimum="-900"
                                              SmallChange="5" />
                                <Slider Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Value="{Binding SelectedPreset.NvMemClk, UpdateSourceTrigger=PropertyChanged}"
                                        Maximum="2000"
                                        Minimum="-900"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True" />
                            </Grid>
                        </StackPanel>

                        <TextBlock FontSize="12"
                                   Text="{localization:Localize WarningHardwareDamages}"
                                   TextWrapping="WrapWithOverflow" Margin="0,8,0,0" />
                    </StackPanel>
                </controls:IconExpander>

                <controls:IconExpander Icon="Scales"
                                       IsVisible="{Binding IsIntelSettingsAvailable, UpdateSourceTrigger=PropertyChanged}">
                    <controls:IconExpander.Header>
                        <Grid ColumnDefinitions="*,Auto">
