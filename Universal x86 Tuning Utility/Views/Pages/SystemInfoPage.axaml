                                                       Margin="5"
                                                       Text="tWTRL:" />
                                            <TextBlock Grid.Row="10"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tWTRL}" />
                                            <TextBlock Grid.Row="10"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tWTRS:" />
                                            <TextBlock Grid.Row="10"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tWTRS}" />

                                            <TextBlock Grid.Row="11"
