                                                       Margin="5"
                                                       Text="tMOD:" />
                                            <TextBlock Grid.Row="22"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tMOD}" />
                                            <TextBlock Grid.Row="22"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tMRD:" />
                                            <TextBlock Grid.Row="22"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tMRD}" />

                                            <TextBlock Grid.Row="23"
