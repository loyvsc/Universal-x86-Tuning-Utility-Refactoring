                                            <TextBlock Grid.Row="18"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tWRRDSCDLR:" />
                                            <TextBlock Grid.Row="18"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tWRRDSCDLR}" />

                                            <TextBlock Grid.Row="19"
