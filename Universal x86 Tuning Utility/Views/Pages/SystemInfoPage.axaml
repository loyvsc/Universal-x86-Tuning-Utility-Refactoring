                                            <TextBlock Grid.Row="14"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRDRDSD:" />
                                            <TextBlock Grid.Row="14"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRDRDSD}" />

                                            <TextBlock Grid.Row="15"
