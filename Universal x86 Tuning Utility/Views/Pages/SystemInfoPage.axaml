                                            <TextBlock Grid.Row="8"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tFAWDLR:" />
                                            <TextBlock Grid.Row="8"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tFAWDLR}" />

                                            <TextBlock Grid.Row="9"
