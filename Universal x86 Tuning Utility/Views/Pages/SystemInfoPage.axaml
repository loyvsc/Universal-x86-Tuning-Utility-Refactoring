                                                       Margin="5"
                                                       Text="tRDWR:" />
                                            <TextBlock Grid.Row="19"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tRDWR}" />
                                            <TextBlock Grid.Row="19"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tWRRD:" />
                                            <TextBlock Grid.Row="19"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tWRRD}" />

                                            <TextBlock Grid.Row="20"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tREF:" />
                                            <TextBlock Grid.Row="20"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tREF}" />
                                            <TextBlock Grid.Row="20"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tREFCT:" />
                                            <TextBlock Grid.Row="20"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tREFCT}" />

                                            <TextBlock Grid.Row="21"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tMODPDA:" />
                                            <TextBlock Grid.Row="21"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tMODPDA}" />
                                            <TextBlock Grid.Row="21"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tMRDPDA:" />
                                            <TextBlock Grid.Row="21"
