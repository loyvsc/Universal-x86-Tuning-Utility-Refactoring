                                                       Text="{Binding tRCPage}" />
                                            <TextBlock Grid.Row="12"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRDRDBAN:" />
                                            <TextBlock Grid.Row="12"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRDRDBAN}" />

                                            <TextBlock Grid.Row="13"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tRDRDSCL:" />
                                            <TextBlock Grid.Row="13"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tRDRDSCL}" />
                                            <TextBlock Grid.Row="13"
