                                                       Margin="5"
                                                       Text="tRDRDSCDLR:" />
                                            <TextBlock Grid.Row="13"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRDRDSCDLR}" />

                                            <TextBlock Grid.Row="14"
