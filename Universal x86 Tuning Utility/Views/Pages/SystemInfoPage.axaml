<UserControl x:Class="Universal_x86_Tuning_Utility.Views.Pages.SystemInfoPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Universal_x86_Tuning_Utility.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ApplicationCore.Models;assembly=ApplicationCore"
             xmlns:viewModels="clr-namespace:Universal_x86_Tuning_Utility.ViewModels"
             d:DesignHeight="720"
             d:DesignWidth="1280"
             x:DataType="viewModels:SystemInfoViewModel"
             mc:Ignorable="d">
    <DockPanel Margin="15,0,0,0">
        <TextBlock Margin="3,10,0,0"
                   DockPanel.Dock="Top"
                   FontSize="{StaticResource HeaderFontSize}"
                   FontWeight="Medium"
                   Text="System Info" />

        <ScrollViewer Margin="0,12,0,0"
                      DockPanel.Dock="Top"
                      HorizontalScrollBarVisibility="Auto"
                      IsDeferredScrollingEnabled="False"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,15,15" Spacing="9">
                <controls:IconExpander VerticalAlignment="Top"
                                       FontWeight="Medium"
                                       Header="Device Information"
                                       Icon="Desktop"
                                       IsExpanded="True">

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Width="80"
                                    Margin="24,0,12,0"
                                    Spacing="8">
                            <TextBlock FontWeight="DemiBold" Text="Name" />
                            <TextBlock FontWeight="DemiBold" Text="Producer" />
                            <TextBlock FontWeight="DemiBold" Text="Model" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding DeviceManufacturer, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding DeviceModel, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>
                <controls:IconExpander VerticalAlignment="Top"
                                       FontWeight="Medium"
                                       Header="Processor Information"
                                       Icon="DeveloperBoard"
                                       IsExpanded="True">

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Width="80"
                                        Margin="24,0,12,0"
                                        Spacing="8">
                                <TextBlock FontWeight="DemiBold" Text="Processor" />
                                <TextBlock FontWeight="DemiBold" Text="Producer" />
                                <TextBlock FontWeight="DemiBold" Text="Codename" />
                                <TextBlock FontWeight="DemiBold" Text="Caption" />
                                <TextBlock FontWeight="DemiBold" Text="Cores" />
                                <TextBlock FontWeight="DemiBold" Text="Threads" />
                                <TextBlock FontWeight="DemiBold" Text="Base Clock" />
                                <TextBlock FontWeight="DemiBold" Text="L1 Cache" />
                                <TextBlock FontWeight="DemiBold" Text="L2 Cache" />
                                <TextBlock FontWeight="DemiBold" Text="L3 Cache" />
                                <TextBlock FontWeight="DemiBold" Text="Instructions" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding CpuInfo.Name}" />
                                <TextBlock Text="{Binding CpuInfo.Manufacturer}" />
                                <TextBlock Text="{Binding CpuInfo.CodeName}" />
                                <TextBlock Text="{Binding CpuInfo.Description}" />
                                <TextBlock Text="{Binding CpuCoresInfo, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding CpuInfo.LogicalCoresCount}" />
                                <TextBlock Text="{Binding CpuBaseClock, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding CpuL1Cache, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding CpuL2Cache, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding CpuL3Cache, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding CpuInstructions, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>
                <controls:IconExpander VerticalAlignment="Top"
                                       FontWeight="Medium"
                                       Header="Memory Information"
                                       Icon="Ram"
                                       IsExpanded="True">

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Width="80"
                                        Margin="24,0,12,0"
                                        Spacing="8">
                                <TextBlock FontWeight="DemiBold" Text="Memory" />
                                <TextBlock FontWeight="DemiBold" Text="Producer" />
                                <TextBlock FontWeight="DemiBold" Text="Model" />
                                <TextBlock FontWeight="DemiBold" Text="Width" />
                                <TextBlock FontWeight="DemiBold" Text="Modules" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding RamInfo, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding RamProducer, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding RamModel, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding RamWidth, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding RamSlots, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="24,8,12,0">
                            <TextBlock FontWeight="DemiBold" Text="RAM Timings:" />

                            <ContentControl Content="{Binding RamTimings, UpdateSourceTrigger=PropertyChanged}">
                                <ContentControl.DataTemplates>
                                    <DataTemplate DataType="models:RyzenMemoryTimings">
                                        <Grid Margin="-5,8,0,0"
                                              ColumnDefinitions="2*,*,2*,*"
                                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="BGS:" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding BGS}" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="BGSA:" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding BGSA}" />

                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="Preamble2T:" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding Preamble2T}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="GDM:" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding GDM}" />

                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="Command Rate:" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding CommandRate}" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRCDWR:" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRCDWR}" />

                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tRCDRD:" />
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tRCDRD}" />
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRAS:" />
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRAS}" />

                                            <TextBlock Grid.Row="4"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tCL:" />
                                            <TextBlock Grid.Row="4"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tCL}" />
                                            <TextBlock Grid.Row="4"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRPPB:" />
                                            <TextBlock Grid.Row="4"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRPPB}" />

                                            <TextBlock Grid.Row="5"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tRP:" />
                                            <TextBlock Grid.Row="5"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tRP}" />
                                            <TextBlock Grid.Row="5"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRCPB:" />
                                            <TextBlock Grid.Row="5"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRCPB}" />

                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tRC:" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tRC}" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRTP:" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRTP}" />

                                            <TextBlock Grid.Row="7"
                                                       Grid.Column="0"
                                                       Margin="5"
                                                       Text="tRRDDLR:" />
                                            <TextBlock Grid.Row="7"
                                                       Grid.Column="1"
                                                       Margin="5"
                                                       Text="{Binding tRRDDLR}" />
                                            <TextBlock Grid.Row="7"
                                                       Grid.Column="2"
                                                       Margin="5"
                                                       Text="tRRDL:" />
                                            <TextBlock Grid.Row="7"
                                                       Grid.Column="3"
                                                       Margin="5"
                                                       Text="{Binding tRRDL}" />

                                            <TextBlock Grid.Row="8"
