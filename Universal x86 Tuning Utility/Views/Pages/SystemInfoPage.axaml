                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>
                <controls:IconExpander VerticalAlignment="Top"
                                       FontWeight="Medium"
                                       Header="Battery Information"
                                       Icon="Battery9"
                                       IsExpanded="True"
                                       IsVisible="{Binding IsBatteryInfoAvailable, UpdateSourceTrigger=PropertyChanged}">

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Width="80"
                                        Margin="24,0,12,0"
                                        Spacing="8">
                                <TextBlock FontWeight="DemiBold" Text="Health" />
                                <TextBlock FontWeight="DemiBold" Text="Cycles" />
                                <TextBlock FontWeight="DemiBold" Text="Capacity" />
                                <TextBlock FontWeight="DemiBold" Text="Charge Rate" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding BatteryHealth, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding BatteryCycle, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding BatteryCapacity, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding BatteryChargeRate, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </controls:IconExpander>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>