<Application x:Class="Universal_x86_Tuning_Utility.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:styling="using:FluentAvalonia.Styling"
             RequestedThemeVariant="Dark">
    
    <Application.Styles>
        <StyleInclude Source="Resources/ControlsStyles.axaml"/>
        <styling:FluentAvaloniaTheme PreferSystemTheme="False" PreferUserAccentColor="True" />
    </Application.Styles>
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/Resources/DefaultValues.axaml"/>
                <MergeResourceInclude Source="/Resources/ControlThemes.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/applicationIcon-1024.png" 
                      ToolTipText="Universal x86 Tuning Utility"
                      Clicked="OnTrayIconClicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Close Application" 
                                        Click="OnCloseMenuItemClicked"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
